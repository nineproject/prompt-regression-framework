{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["caseId", "baselineRunId", "approvedAt"],
  "properties": {
    "caseId": {
      "type": "string",
      "pattern": "^TC-\\d{4}$"
    },
    "baselineRunId": {
      "type": "string",
      "pattern": "^RUN_"
    },
    "approvedAt": {
      "type": "string",
      "minLength": 1
    },
    "approvedBy": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["active", "archived"]
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
